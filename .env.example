# ==========================================================================
# Kapso Sales Dashboard — environment variables
# ==========================================================================
# Copy to .env.local for local dev. NEVER commit real values.
#
# IMPORTANT SECURITY MODEL
# ------------------------
# This file contains ONLY infrastructure secrets + non-secret config.
#
# Per-store API credentials — the Shopify Admin API access token, the
# Shopify API secret key (for webhook HMAC) and the Kapso Platform API key —
# are NOT stored here and NOT in the repo. They are entered at runtime in the
# "Connect store" screen and persisted AES-GCM-encrypted in the database
# (encrypted with ENCRYPTION_KEY). They are decrypted only server-side, on
# demand, and never sent to the browser.
# ==========================================================================

# --- Supabase (Postgres + Auth) ---
# Public client config (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Service-role key — SERVER ONLY. Bypasses RLS; used by ingestion
# (webhooks, cron) to write rows. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Direct Postgres connection string — used to apply SQL migrations
# (db/migrations/*.sql, supabase/policies.sql) via psql / the Supabase CLI.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres"

# --- App crypto ---
# 32-byte key for AES-256-GCM token encryption, base64-encoded.
# Generate with:  openssl rand -base64 32
ENCRYPTION_KEY="base64-encoded-32-byte-key"

# --- Cron protection ---
# Shared secret required to invoke /api/cron/sync (Authorization: Bearer <secret>
# or ?secret=<secret>). Vercel Cron sends the Authorization header automatically.
# Generate with:  openssl rand -hex 32
CRON_SECRET="your-cron-secret"

# --- Non-secret runtime config ---
# Public origin of the deployed app. Used to build Shopify webhook callback URLs
# and Supabase auth redirect URLs.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Shopify Admin API version used for GraphQL calls (YYYY-MM).
SHOPIFY_API_VERSION="2025-01"

# Kapso Platform API base URL (override only if Kapso changes hosts).
KAPSO_API_BASE="https://api.kapso.ai/platform/v1"
